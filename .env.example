# =============================================================
# VAULT - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores
# =============================================================
# ATENÇÃO: Nunca commite .env ou .env.local com valores reais!
# Apenas este arquivo (.env.example) deve ir para o git.
# =============================================================

# ── Supabase (obrigatório) ──────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App ────────────────────────────────────────────────────
VITE_APP_NAME=Vault - Caixa Alerta
# Nota: a autenticação usa window.location.origin (nunca URL fixa).
# Não defina URLs de app/redirect por env — evita vazar localhost para produção.

# ── Analytics (PostHog) ────────────────────────────────────
# Encontre em: PostHog → Project Settings → Project API Key
VITE_POSTHOG_KEY=phc_your-project-key-here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Feature Flags ──────────────────────────────────────────
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_BANK_INTEGRATION=false

# ── Push Notifications (VAPID) ─────────────────────────────
# Gere novas chaves com: npx web-push generate-vapid-keys
# A chave pública vai aqui (pode ser exposta no frontend)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
# A chave privada NÃO usa prefixo VITE_ (não entra no bundle)
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# ── NUNCA coloque aqui ─────────────────────────────────────
# VITE_PLUGGY_CLIENT_SECRET → usar Supabase Edge Function secrets
# VITE_OPENAI_API_KEY       → usar Supabase Edge Function secrets
# Qualquer VITE_*_SECRET    → Vite embute no bundle JS (inseguro!)
#
# Configure secrets no Edge Functions via:
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set PLUGGY_CLIENT_SECRET=...
